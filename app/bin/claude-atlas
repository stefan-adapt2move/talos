#!/bin/bash
# Claude Atlas Wrapper — Injects system prompt, model, and MCP config for trigger sessions.
# Usage: claude-atlas [--resume <id>] [-p] [--dangerously-skip-permissions] [--output-format json] "<prompt>"
set -euo pipefail

APP_DIR="/atlas/app"
WORKSPACE="$HOME"

# Parse arguments: extract --resume, pass everything else through
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        --mode) shift 2 ;; # ignored — only trigger mode exists
        --resume) CLAUDE_ARGS+=(--resume "$2"); shift 2 ;;
        *) CLAUDE_ARGS+=("$1"); shift ;;
    esac
done

# --- Resolve model from config.yml (unless --model was already passed) ---
HAS_MODEL_FLAG=false
for arg in "${CLAUDE_ARGS[@]}"; do
    [[ "$arg" == "--model" ]] && HAS_MODEL_FLAG=true && break
done

MODEL="opus"  # default for triggers
if [ "$HAS_MODEL_FLAG" = false ]; then
    CONFIG="${HOME}/config.yml"
    [ -f "$CONFIG" ] || CONFIG="$APP_DIR/defaults/config.yml"

    if [ -f "$CONFIG" ]; then
        MODEL_KEY="trigger"
        [ "${ATLAS_CRON:-}" = "1" ] && MODEL_KEY="cron"
        PARSED=$(python3 -c "
import yaml, sys
c = yaml.safe_load(open(sys.argv[1]))
print(c.get('models', {}).get(sys.argv[2], 'opus'))
" "$CONFIG" "$MODEL_KEY" 2>/dev/null) || true
        [ -n "$PARSED" ] && MODEL="$PARSED"
    fi
fi

# --- Build system prompt: SOUL + IDENTITY + trigger-system-prompt + channel ---
SYSTEM_PROMPT=""

for section in \
    "soul:$WORKSPACE/SOUL.md" \
    "identity:$WORKSPACE/IDENTITY.md"; do
    TAG="${section%%:*}"
    FILE="${section#*:}"
    [ -f "$FILE" ] && SYSTEM_PROMPT+="
<${TAG} file=\"${FILE}\">
$(cat "$FILE")
</${TAG}>
"
done

[ -f "$APP_DIR/prompts/trigger-system-prompt.md" ] && \
    SYSTEM_PROMPT+="
---

$(cat "$APP_DIR/prompts/trigger-system-prompt.md")"

CHANNEL="${ATLAS_TRIGGER_CHANNEL:-internal}"
[ -f "$APP_DIR/prompts/trigger-channel-${CHANNEL}.md" ] && \
    SYSTEM_PROMPT+="
---

$(cat "$APP_DIR/prompts/trigger-channel-${CHANNEL}.md")"

# --- MCP config: merge system + user layers into one file ---
# --mcp-config is variadic and consumes all subsequent args, so we produce one merged file.
MCP_DIR="$HOME/.atlas-mcp"
mkdir -p "$MCP_DIR"

# Defaults (only written if missing — user edits persist across restarts)
[ -f "$MCP_DIR/system.json" ] || cat > "$MCP_DIR/system.json" << 'EOF'
{
  "mcpServers": {
    "work": {
      "command": "bun",
      "args": ["run", "/atlas/app/atlas-mcp/index.ts"]
    },
    "memory": {
      "command": "qmd",
      "args": ["mcp"]
    }
  }
}
EOF

[ -f "$MCP_DIR/atlas.json" ]  || printf '{\n  "mcpServers": {}\n}\n' > "$MCP_DIR/atlas.json"
[ -f "$MCP_DIR/user.json" ]   || cat > "$MCP_DIR/user.json" << 'EOF'
{
  "mcpServers": {
    "playwright": {
      "url": "http://localhost:8931/sse"
    }
  }
}
EOF

MCP_MERGED="$MCP_DIR/.merged.json"
python3 -c "
import json, sys
merged = {'mcpServers': {}}
for f in sys.argv[2:]:
    try:
        for name, cfg in json.load(open(f)).get('mcpServers', {}).items():
            if 'url' not in cfg:  # skip url-based servers (cause silent exit via --mcp-config)
                merged['mcpServers'][name] = cfg
    except: pass
json.dump(merged, open(sys.argv[1], 'w'), indent=2)
" "$MCP_MERGED" "$MCP_DIR/system.json" "$MCP_DIR/atlas.json" "$MCP_DIR/user.json"

# --- Assemble final command ---
# Separate flags from positional args (the prompt), because --mcp-config must come last before --.
FLAGS=()
POSITIONAL=()
SKIP=false
for arg in "${CLAUDE_ARGS[@]}"; do
    if $SKIP; then FLAGS+=("$arg"); SKIP=false; continue; fi
    case "$arg" in
        --output-format|--model|--resume) FLAGS+=("$arg"); SKIP=true ;;
        -*) FLAGS+=("$arg") ;;
        *)  POSITIONAL+=("$arg") ;;
    esac
done

FINAL=(--append-system-prompt "$SYSTEM_PROMPT")
[ "$HAS_MODEL_FLAG" = false ] && FINAL+=(--model "$MODEL")
FINAL+=("${FLAGS[@]}" --mcp-config "$MCP_MERGED" -- "${POSITIONAL[@]}")

export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
exec claude "${FINAL[@]}"
