#!/bin/bash
# Claude Atlas Wrapper - Injects system prompt based on session type
set -euo pipefail

APP_DIR="/atlas/app"
WORKSPACE="$HOME"

# Parse arguments
MODE=""  # "worker" or "trigger"
RESUME=""
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --mode)
            MODE="$2"
            shift 2
            ;;
        --resume)
            RESUME="$2"
            CLAUDE_ARGS+=(--resume "$RESUME")
            shift 2
            ;;
        *)
            CLAUDE_ARGS+=("$1")
            shift
            ;;
    esac
done

# Resolve model from config.yml (unless --model was already passed)
HAS_MODEL_FLAG=false
for arg in "${CLAUDE_ARGS[@]}"; do
    if [[ "$arg" == "--model" ]]; then
        HAS_MODEL_FLAG=true
        break
    fi
done

if [ "$HAS_MODEL_FLAG" = false ]; then
    CONFIG=""
    if [ -f "$HOME/config.yml" ]; then
        CONFIG="$HOME/config.yml"
    elif [ -f "$APP_DIR/defaults/config.yml" ]; then
        CONFIG="$APP_DIR/defaults/config.yml"
    fi

    MODEL="sonnet"  # default fallback
    if [ -n "$CONFIG" ]; then
        # Resolve model based on session mode
        # Mode-to-config mapping: trigger→trigger, worker/worker-ephemeral→worker, reviewer→reviewer
        # Cron triggers set ATLAS_CRON=1 to select the cron model
        MODEL_KEY="worker"  # default for unknown modes
        case "$MODE" in
            trigger)
                if [ "${ATLAS_CRON:-}" = "1" ]; then
                    MODEL_KEY="cron"
                else
                    MODEL_KEY="trigger"
                fi
                ;;
            worker-ephemeral) MODEL_KEY="worker" ;;
            reviewer) MODEL_KEY="reviewer" ;;
        esac
        PARSED_MODEL=$(python3 -c "
import yaml, sys
c = yaml.safe_load(open(sys.argv[1]))
models = c.get('models', {})
print(models.get(sys.argv[2], models.get('worker', 'sonnet')))
" "$CONFIG" "$MODEL_KEY" 2>/dev/null) || true
        if [ -n "$PARSED_MODEL" ]; then
            MODEL="$PARSED_MODEL"
        fi
    fi
fi

# Build system prompt content
SYSTEM_PROMPT=""


if [ "$MODE" = "worker-ephemeral" ]; then
    # Ephemeral worker: minimal prompt, no memory, no inbox MCP
    export ATLAS_WORKER_EPHEMERAL=1
    if [ -f "$APP_DIR/prompts/worker-ephemeral-prompt.md" ]; then
        SYSTEM_PROMPT="$(cat "$APP_DIR/prompts/worker-ephemeral-prompt.md")"
    fi

elif [ "$MODE" = "reviewer" ]; then
    # Review agent: verifies worker output against acceptance criteria
    export ATLAS_REVIEWER=1
    if [ -f "$APP_DIR/prompts/reviewer-system-prompt.md" ]; then
        SYSTEM_PROMPT="$(cat "$APP_DIR/prompts/reviewer-system-prompt.md")"
    fi

elif [ "$MODE" = "trigger" ]; then
    if [ -f "$WORKSPACE/SOUL.md" ]; then
        SYSTEM_PROMPT="$SYSTEM_PROMPT

<soul file=\"$WORKSPACE/SOUL.md\">
$(cat "$WORKSPACE/SOUL.md")
</soul>"
    fi

    if [ -f "$WORKSPACE/IDENTITY.md" ]; then
        SYSTEM_PROMPT="$SYSTEM_PROMPT

<identity file=\"$WORKSPACE/IDENTITY.md\">
$(cat "$WORKSPACE/IDENTITY.md")
</identity>"
    fi

    # Trigger sessions: add trigger-system-prompt (communication style/restrictions) + soul + identity + trigger-specific prompts
    if [ -f "$APP_DIR/prompts/trigger-system-prompt.md" ]; then
        SYSTEM_PROMPT="$SYSTEM_PROMPT

---

$(cat "$APP_DIR/prompts/trigger-system-prompt.md")"
    fi

    CHANNEL="${ATLAS_TRIGGER_CHANNEL:-internal}"
    if [ -f "$APP_DIR/prompts/trigger-channel-${CHANNEL}.md" ]; then
        SYSTEM_PROMPT="$SYSTEM_PROMPT

---

$(cat "$APP_DIR/prompts/trigger-channel-${CHANNEL}.md")"
    fi
fi

# --- Dynamic MCP config per mode ---
ATLAS_MCP_DIR="$HOME/.atlas-mcp"
mkdir -p "$ATLAS_MCP_DIR"

# Create default files if missing
if [ ! -f "$ATLAS_MCP_DIR/system.json" ]; then
  cat > "$ATLAS_MCP_DIR/system.json" << 'SYSTEM_EOF'
{
  "mcpServers": {
    "inbox": {
      "command": "bun",
      "args": ["run", "/atlas/app/inbox-mcp/index.ts"]
    },
    "memory": {
      "command": "qmd",
      "args": ["mcp"]
    }
  }
}
SYSTEM_EOF
fi

if [ ! -f "$ATLAS_MCP_DIR/atlas.json" ]; then
  printf '{\n  "mcpServers": {}\n}\n' > "$ATLAS_MCP_DIR/atlas.json"
fi

if [ ! -f "$ATLAS_MCP_DIR/user.json" ]; then
  cat > "$ATLAS_MCP_DIR/user.json" << 'USER_EOF'
{
  "mcpServers": {
    "playwright": {
      "url": "http://localhost:8931/sse"
    }
  }
}
USER_EOF
fi

# Select and merge MCP configs based on mode into a single file.
# --mcp-config is variadic and consumes all subsequent args including --,
# so we MUST pass exactly one merged config file.
MCP_SOURCES=()
if [ "$MODE" = "trigger" ]; then
  MCP_SOURCES+=("$ATLAS_MCP_DIR/system.json" "$ATLAS_MCP_DIR/atlas.json" "$ATLAS_MCP_DIR/user.json")
elif [ "$MODE" = "worker" ] || [ "$MODE" = "worker-ephemeral" ] || [ "$MODE" = "reviewer" ]; then
  MCP_SOURCES+=("$ATLAS_MCP_DIR/user.json")
fi

MCP_MERGED=""
if [ ${#MCP_SOURCES[@]} -gt 0 ]; then
  MCP_MERGED="$ATLAS_MCP_DIR/.merged-${MODE}.json"
  python3 -c "
import json, sys
merged = {'mcpServers': {}}
for f in sys.argv[1:]:
    try:
        data = json.load(open(f))
        merged['mcpServers'].update(data.get('mcpServers', {}))
    except: pass
json.dump(merged, open(sys.argv[0], 'w'), indent=2)
" "$MCP_MERGED" "${MCP_SOURCES[@]}"
fi

# Build final claude arguments.
# --mcp-config is variadic (<configs...>) and greedily consumes all subsequent
# arguments. It MUST be placed last, right before -- and the positional prompt.
#
# Separate CLAUDE_ARGS into flags (options) and positional args (the prompt).
CLAUDE_FLAGS=()
CLAUDE_POSITIONAL=()
SKIP_NEXT=false
for i in "${!CLAUDE_ARGS[@]}"; do
    if $SKIP_NEXT; then
        CLAUDE_FLAGS+=("${CLAUDE_ARGS[$i]}")
        SKIP_NEXT=false
        continue
    fi
    case "${CLAUDE_ARGS[$i]}" in
        --output-format|--model|--resume)
            CLAUDE_FLAGS+=("${CLAUDE_ARGS[$i]}")
            SKIP_NEXT=true
            ;;
        -*)
            CLAUDE_FLAGS+=("${CLAUDE_ARGS[$i]}")
            ;;
        *)
            CLAUDE_POSITIONAL+=("${CLAUDE_ARGS[$i]}")
            ;;
    esac
done

FINAL_ARGS=()
if [ -n "$SYSTEM_PROMPT" ]; then
    FINAL_ARGS+=(--append-system-prompt "$SYSTEM_PROMPT")
fi
# Inject --model from config if not already provided
if [ "$HAS_MODEL_FLAG" = false ]; then
    FINAL_ARGS+=(--model "$MODEL")
fi
if [ -n "$MCP_MERGED" ]; then
    FINAL_ARGS+=(--strict-mcp-config)
fi
FINAL_ARGS+=("${CLAUDE_FLAGS[@]}")
# --mcp-config with a single merged file, right before -- and the prompt
if [ -n "$MCP_MERGED" ]; then
    FINAL_ARGS+=(--mcp-config "$MCP_MERGED")
fi
FINAL_ARGS+=(--)
FINAL_ARGS+=("${CLAUDE_POSITIONAL[@]}")

export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
exec claude "${FINAL_ARGS[@]}"
